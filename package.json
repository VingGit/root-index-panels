{
  "name": "@quartz-community/root-index-panels",
  "version": "0.1.1",
  "description": "Quartz 5 plugin that replaces the root index page with a responsive card grid of first-level vault directories.",
  "type": "module",
  "license": "MIT",
  "author": "VingGit",
  "homepage": "https://github.com/VingGit/root-index-panels",
  "repository": {
    "type": "git",
    "url": "https://github.com/VingGit/root-index-panels"
  },
  "keywords": [
    "quartz",
    "quartz-plugin",
    "quartz5",
    "folder-page",
    "directory",
    "cards",
    "index",
    "component"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier . --check",
    "test": "vitest run",
    "test:integration": "node test/integration/parent-build.mjs",
    "test:watch-integration": "node test/integration/watch-build.mjs",
    "typecheck": "tsc --noEmit",
    "verify:dist": "node scripts/check-dist-externals.mjs",
    "verify:package": "node scripts/check-packed-package.mjs",
    "check": "npm run typecheck && npm run lint && npm run format && npm run test"
  },
  "peerDependencies": {
    "preact": "^10.27.2"
  },
  "peerDependenciesMeta": {
    "preact": {
      "optional": false
    }
  },
  "dependencies": {
    "@quartz-community/types": "github:quartz-community/types",
    "@quartz-community/utils": "github:quartz-community/utils",
    "github-slugger": "^2.0.0",
    "lucide-preact": "1.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "happy-dom": "20.10.6",
    "preact": "^10.28.2",
    "preact-render-to-string": "^6.6.5",
    "prettier": "^3.6.2",
    "sass": "^1.97.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "quartz": {
    "name": "root-index-panels",
    "displayName": "Root Index Panels",
    "description": "Renders first-level vault directories as panels on the root index page.",
    "author": "VingGit",
    "homepage": "https://github.com/VingGit/root-index-panels",
    "keywords": [
      "quartz",
      "quartz-plugin",
      "quartz5",
      "folder-page",
      "directory",
      "cards",
      "index",
      "component"
    ],
    "category": [
      "pageType",
      "component"
    ],
    "version": "0.1.1",
    "quartzVersion": ">=5.0.0",
    "dependencies": [],
    "defaultOrder": 50,
    "defaultEnabled": false,
    "defaultOptions": {
      "layout": "cards",
      "showDescription": true,
      "showDocCount": true,
      "showTags": true,
      "tagCount": 3,
      "sort": "alphabetical",
      "excludeDirs": [],
      "descriptionFallback": "",
      "defaultIcon": "",
      "defaultAccent": "theme",
      "accents": {}
    },
    "configSchema": {
      "layout": {
        "type": "enum",
        "values": [
          "cards",
          "list"
        ]
      },
      "sort": {
        "type": "enum",
        "values": [
          "alphabetical",
          "docCount",
          "date"
        ]
      },
      "showDescription": {
        "type": "boolean"
      },
      "showDocCount": {
        "type": "boolean"
      },
      "showTags": {
        "type": "boolean"
      },
      "tagCount": {
        "type": "number"
      },
      "excludeDirs": {
        "type": "array"
      },
      "descriptionFallback": {
        "type": "string"
      },
      "defaultIcon": {
        "type": "string"
      },
      "defaultAccent": {
        "type": "string"
      }
    },
    "components": {
      "RootIndexPanels": {
        "name": "RootIndexPanels",
        "displayName": "Root Index Panels",
        "description": "Directory panel grid for the root index page.",
        "version": "0.1.1",
        "quartzVersion": ">=5.0.0",
        "author": "VingGit",
        "homepage": "https://github.com/VingGit/root-index-panels"
      }
    }
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10.9.2"
  }
}
